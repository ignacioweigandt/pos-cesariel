# ============================================
# PRODUCCIÓN - POS CESARIEL
# ============================================
# IMPORTANTE: Copiar este archivo a .env.production y configurar con valores reales

# === DATABASE ===
DB_NAME=pos_cesariel
DB_USER=postgres
DB_PASSWORD=CAMBIAR_EN_PRODUCCION
DB_HOST=db
DB_PORT=5432

# === BACKEND (FastAPI) ===
ENV=production
DEBUG=false
JWT_SECRET_KEY=CAMBIAR_CLAVE_SECRETA_PRODUCCION_MUY_SEGURA
JWT_EXPIRE_MINUTES=480

# === FRONTEND ===
NEXT_PUBLIC_API_URL=https://tu-dominio.com/api
# Para server-side en Docker
API_URL=http://backend:8000

# === PUERTOS (Opcional - usar defaults) ===
BACKEND_PORT=8000
FRONTEND_PORT=3000
ECOMMERCE_PORT=3001

# === CLOUDINARY (Imágenes) ===
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# === CORS (Opcional) ===
ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
